# Server
NODE_ENV=production
PORT=5000
API_BODY_LIMIT=5mb

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/edusn

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-too
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated allowed origins (admin/staff URLs)
# Example: https://edusn.co.uk,https://www.edusn.co.uk
FRONTEND_URL=https://edusn.co.uk
ADMIN_URL=https://edusn.co.uk
CORS_ORIGINS=https://edusn.co.uk,https://www.edusn.co.uk

# Public URL of this backend (used for local file upload links)
BACKEND_URL=https://edusn.co.uk

# Production server options
TRUST_PROXY=true
# Set true only when the backend is the root entrypoint and should redirect / to /admin/login
ROOT_REDIRECT_ADMIN=false

# Cloudinary (images/videos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OTP / Email (required for real OTP delivery)
OTP_EXPIRES_MINUTES=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="EDUSN <no-reply@edusn.co.uk>"
